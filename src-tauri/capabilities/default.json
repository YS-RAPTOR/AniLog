{
    "$schema": "../gen/schemas/desktop-schema.json",
    "identifier": "default",
    "description": "enables the default permissions",
    "windows": [
        "main"
    ],
    "permissions": [
        "core:default",
        "core:event:default",
        "oauth:allow-start",
        "oauth:allow-cancel",
        "deep-link:default",
        "opener:default"
    ]
}
